{
  "name": "pitstop-triage",
  "version": "1.0.0",
  "description": "Plataforma web responsiva de triagem automotiva inteligente com Angular 19, Signals e Vercel Serverless.",
  "scripts": {
    "ng": "ng",
    "predev": "node scripts/predev.mjs",
    "dev": "concurrently -k -n WEB,API -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "ng serve --proxy-config proxy.conf.json --open",
    "dev:api": "tsx scripts/dev-api.mjs",
    "start": "npm run dev",
    "start:full": "vercel dev",
    "build": "ng build",
    "vercel-build": "ng build && tsc -p api/tsconfig.json",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"{src,api}/**/*.{ts,html,css,md,json}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"{src,api}/**/*.{ts,html,css,md,json}\" \"*.{js,json,md}\"",
    "typecheck:api": "tsc -p api/tsconfig.json --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck:api && npm run build"
  },
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "openai": "^4.104.0",
    "jspdf": "^2.5.2",
    "rxjs": "~7.8.1",
    "three": "^0.184.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@types/node": "^22.13.1",
    "@types/three": "^0.184.1",
    "@vercel/node": "^5.1.16",
    "angular-eslint": "21.0.1",
    "concurrently": "10.0.3",
    "dotenv": "17.4.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "8.46.4"
  }
}
