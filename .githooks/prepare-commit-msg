#!/bin/sh
# Remove atribuição automática do Cursor dos commits locais.
# Ative uma vez: git config core.hooksPath .githooks

COMMIT_MSG_FILE=$1
[ -f "$COMMIT_MSG_FILE" ] || exit 0

tmp="${COMMIT_MSG_FILE}.tmp"
grep -vi 'co-authored-by: cursor' "$COMMIT_MSG_FILE" | grep -vi 'made-with: cursor' > "$tmp"
mv "$tmp" "$COMMIT_MSG_FILE"
