{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": "..",
    "paths": {
      "@utils/*": ["src/app/utils/*"],
      "@models/*": ["src/app/models/*"]
    },
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "../src/app/utils/pt-br-ortografia.ts",
    "../src/app/utils/pt-br-text.util.ts",
    "../src/app/utils/refinamento.util.ts",
    "../src/app/models/cdp.model.ts",
    "../src/app/models/refinamento.model.ts",
    "../src/app/models/veiculo.model.ts"
  ]
}
